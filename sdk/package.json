{
  "name": "@agentdid/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for creating, signing, and verifying Agent-DIDs based on RFC-001. Decentralized identity for autonomous AI agents with Ed25519 signatures, HTTP Bot Auth, and EVM registry support.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "did",
    "agent",
    "ai",
    "web3",
    "identity",
    "decentralized-identity",
    "verifiable-credentials",
    "ed25519",
    "agent-did",
    "rfc-001",
    "autonomous-agents",
    "bot-auth",
    "http-signatures",
    "zero-trust"
  ],
  "author": "Edison Munoz <edison.munoz@agent-did.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/edisonduran/Agent-citizen-identification.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/edisonduran/Agent-citizen-identification#readme",
  "bugs": {
    "url": "https://github.com/edisonduran/Agent-citizen-identification/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "bs58": "^6.0.0",
    "ethers": "^6.11.1",
    "multiformats": "^13.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^30.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.2"
  }
}
